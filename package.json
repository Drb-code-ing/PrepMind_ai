{
  "name": "prepmind",
  "private": true,
  "scripts": {
    "dev": "bun --filter @repo/web dev",
    "dev:admin": "bun --filter @repo/admin dev",
    "dev:server": "bun --filter @repo/server start:dev",
    "dev:all": "bun --filter '*' --parallel dev",
    "build": "bun --filter @repo/web build && bun --filter @repo/server build",
    "lint": "bun --filter @repo/web lint && bun --filter @repo/server lint",
    "test": "bun --filter @repo/server test",
    "db:migrate": "bun --filter @repo/database prisma:migrate",
    "db:status": "bun --filter @repo/database prisma:status",
    "db:studio": "bun --filter @repo/database prisma:studio",
    "db:generate": "bun --filter @repo/database prisma:generate",
    "docker:up": "docker compose --env-file .env -f docker/docker-compose.dev.yml up -d",
    "docker:up:worker": "docker compose --env-file .env -f docker/docker-compose.dev.yml --profile worker up -d",
    "docker:down": "docker compose --env-file .env -f docker/docker-compose.dev.yml down"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
